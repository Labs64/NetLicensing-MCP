# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your NetLicensing API key
# Leave empty to use demo credentials (sandbox data only)
NETLICENSING_API_KEY=

# Override the API base URL (optional — leave as default for production)
NETLICENSING_BASE_URL=https://go.netlicensing.io/core/v2/rest

# MCP HTTP-mode host/port (optional, used with `netlicensing-mcp http`)
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

